<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">

    <title>Snuggly Bubbly Paws</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js">
    </script>
</head>

<body>

    <%- include('partials/header') %>

        <img src="/images/clinic.jpg" alt="Snuggly Bubbly Paws Banner" class="img-fluid mt-3">

        <div class="container">

            <h2 class="mt-5">Update Animal Details</h2>

            <p>
                Update the animal's information below.
            </p>

            <% if (errors && errors.length> 0) { %>

                <div class="alert alert-danger">

                    <% errors.forEach(function(error) { %>

                        <p class="mb-0">
                            <%= error %>
                        </p>

                        <% }); %>

                </div>

                <% } %>

                    <form action="/updateAnimal/<%= updateAnimal.animalId %>" method="POST"
                        enctype="multipart/form-data" class="mt-4 mb-5">

                        <!-- Animal ID -->
                        <div class="mb-3">

                            <label for="animalId" class="form-label">
                                Animal ID:
                            </label>

                            <input type="text" id="animalId" class="form-control" value="<%= updateAnimal.animalId %>"
                                readonly>

                        </div>

                        <!-- Animal Name -->
                        <div class="mb-3">

                            <label for="animalName" class="form-label">
                                Animal Name:
                            </label>

                            <input type="text" id="animalName" name="animalName" class="form-control"
                                value="<%= updateAnimal.animalName %>" required>

                        </div>

                        <!-- Species -->
                        <div class="mb-3">

                            <label for="species" class="form-label">
                                Species:
                            </label>

                            <input type="text" id="species" name="species" class="form-control"
                                value="<%= updateAnimal.species %>" required>

                        </div>

                        <!-- Injury -->
                        <div class="mb-3">

                            <label for="injury" class="form-label">
                                Injury:
                            </label>

                            <input type="text" id="injury" name="injury" class="form-control"
                                value="<%= updateAnimal.injury %>" required>

                        </div>

                        <!-- Comments -->
                        <div class="mb-3">

                            <label for="comments" class="form-label">
                                Comments:
                            </label>

                            <textarea id="comments" name="comments" class="form-control" rows="4"
                                required><%= updateAnimal.comments %></textarea>

                        </div>

                        <!-- Current Image -->
                        <% if (updateAnimal.image) { %>

                            <div class="mb-3">

                                <label class="form-label">
                                    Current Animal Image:
                                </label>

                                <br>

                                <img src="/images/<%= updateAnimal.image %>" alt="<%= updateAnimal.animalName %>"
                                    class="img-thumbnail" width="200">

                            </div>

                            <% } %>

                                <!-- Store current image -->
                                <input type="hidden" name="currentImage" value="<%= updateAnimal.image || '' %>">

                                <!-- New Image -->
                                <div class="mb-3">

                                    <label for="image" class="form-label">
                                        Change Animal Image:
                                    </label>

                                    <input type="file" id="image" name="image" class="form-control" accept="image/*">

                                    <small class="text-muted">
                                        Leave this empty to keep the current image.
                                    </small>

                                </div>

                                <button type="submit" class="btn btn-primary">

                                    Update Animal

                                </button>

                                <a href="/viewAnimal" class="btn btn-secondary">

                                    Cancel

                                </a>

                    </form>

        </div>

</body>

</html>