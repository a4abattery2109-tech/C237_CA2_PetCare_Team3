<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Filter by Animal Name or Comments</title>
</head>

<body>

    <%- include('partials/header') %>

        <div class="container py-5">

            <h2>Filter by Animal Name or Comments</h2>

            <form action="/filter" method="GET">

                <div class="mb-3">
                    <label for="keyword" class="form-label">
                        Keyword by Animal Name or Comments:
                    </label>

                    <input type="text" class="form-control" id="keyword" name="keyword"
                        placeholder="Enter animal name or comment">
                </div>

                <button type="submit" class="btn btn-primary">Filter</button>
                <a href="/filter" class="btn btn-secondary">Reset</a>

            </form>

            <table class="table table-striped mt-4">
                <thead>
                    <tr>
                        <th>Animal Name</th>
                        <th>Species</th>
                        <th>Description of Injury</th>
                        <th>Comments from Veterinarian</th>
                    </tr>
                </thead>

                <tbody>

                    <% if (animals.length===0) { %>

                        <tr>
                            <td colspan="4" class="text-center">
                                No such animals match the filter criteria.
                            </td>
                        </tr>

                        <% } else { %>

                            <% animals.forEach(animal=> { %>

                                <tr>
                                    <td>
                                        <%= animal.animalName %>
                                    </td>
                                    <td>
                                        <%= animal.species %>
                                    </td>
                                    <td>
                                        <%= animal.injury %>
                                    </td>
                                    <td>
                                        <%= animal.comments %>
                                    </td>
                                </tr>

                                <% }) %>

                                    <% } %>

                </tbody>
            </table>

        </div>

</body>

</html>