<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Filter by Rating and Keyword</title>
</head>

<body>
    <!-- Activity 4: Insert code here to include the header (found in the partials folder) to your page -->
    <%- include('partials/header') %>
        <form action="/filter" method="GET">
            <div class="container py-5">
                <h2>Filter by Animal List</h2>

                <table class="table table-striped mt-4">
                    <thead>
                        <tr>
                            <th>Animal Name</th>
                            <th>Species</th>
                            <th>Description of Injury</th>
                            <th>History</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (animals.length===0) { %>
                            <tr>
                                <td colspan="5" class="text-center">
                                    No such animals match the filter criteria.
                                </td>
                            </tr>
                            <% } else { %>
                                <% animals.forEach(animal=> { %>
                                    <tr>
                                        <td>
                                            <%= animal.animalName %>
                                        </td>
                                        <td>
                                            <%= animal.species %>
                                        </td>
                                        <td>
                                            <%= animal.injury %>
                                        </td>
                                        <td>
                                            <%= animal.history %>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>

                    </tbody>
                </table>
            </div>
</body>

</html>