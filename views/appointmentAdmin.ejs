<!DOCTYPE html>
<html>

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
        <div class="container">
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
            <br>
            <div class="text-center">
                <h2>Appointment List</h2>
            </div>
            <br>
            <table class="table table-hover small text-center">
                <thead>
                    <tr>
                        <th width="100">User ID</th>
                        <th width="100">Animal ID</th>
                        <th width="50">Appointment Date</th>
                        <th width="100">Reason for appointment</th>
                        <th width="50">Comments</th>
                        <th width="50">Edit</th>
                        <th width="100">Delete</th>
                        <th width="50">View Animal Information</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let i=0; i < appointment.length; i++) { %>
                        <tr>
                            <td>
                                <%= appointment[i].userid %>
                            </td>
                            <td><a href="/animal/<%= appointment[i].animalId %>">
                                    <%= appointment[i].animalId %>
                                </a></td>
                            <td>
                                <%= appointment[i].appointmentdate %>
                            </td>
                            <td>
                                <%= appointment[i].reason %>
                            </td>
                            <td>
                                <%= appointment[i].comments %>
                            </td>
                            <!-- Edit Link -->
                            <td><a href="/updateAppointment/<%= appointment[i].appointmentId %>">Edit</a></td>
                            <!-- Delete Link -->
                            <td><a href="/deleteAppointment/<%= appointment[i].appointmentId %>"
                                    onclick="return confirm('Are you sure you want to delete this appointment?')">Delete</a>
                            </td>
                            <td><a href="/animal/<%= appointment[i].animalId %>">View Animal Information</a></td>
                        </tr>
                        <% } %>
                        <a href="/addAppointment" class="btn btn-primary">Add Appointment</a>
                </tbody>
            </table>
        </div>
</body>

</html>