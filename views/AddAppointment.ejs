<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  <!-- Navigation Bar -->
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">Supermarket App</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="collapsibleNavbar">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link" href="/addAppointment">Add new appointment</a>
            </li> 
          </ul>
        </div>
      </div>
    </nav>

  <!-- Form -->
  <div class="container mt-5">

    <div class="row justify-content-center">

      <div class="col-md-6">

        <div class="card shadow">

          <div class="card-header bg-secondary text-white">
            <h3 class="mb-0">Add New Appointment</h3>
          </div>

          <div class="card-body">

            <form action="/addAppointment" method="POST" enctype="multipart/form-data">

            <div class="mb-3">
                    <label for="date" class="form-label">
                    AppointmentDate
                    </label>
    
                    <input type="date" class="form-control" id="date" name="date" required>

            <div class="d-grid gap-2">

            <div class="mb-3">
                <label for="name" class="form-label">
                  Reason for Appointment
                </label>

                <input type="text" class="form-control" id="name" name="name" placeholder="Enter product name" required>
              </div>
              
              <div class="mb-3">
                <label for="name" class="form-label">
                  Comments (Type Nil if no comments)
                </label>

                <input type="text" class="form-control" id="name" name="name" placeholder="Enter product name" required>
              </div>

                <button type="submit" class="btn btn-success">
                  Add Appointment
                </button>

                <a href="/" class="btn btn-secondary">
                  Cancel
                </a>

              </div>

            </form>

          </div>

        </div>

      </div>

    </div>

  </div>

</body>

</html>