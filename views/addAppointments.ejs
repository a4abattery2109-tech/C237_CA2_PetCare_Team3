<!DOCTYPE html>
<html lang="en">

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</head>

<body class="bg-light">
  <%- include('partials/header') %>

  <!-- Form -->
  <div class="container mt-5">

    <div class="row justify-content-center">

      <div class="col-md-6">

        <div class="card shadow">

          <div class="card-header bg-secondary text-white">
            <h3 class="mb-0">Add New Appointment</h3>
          </div>

          <div class="card-body">

            <form action="/addAppointment" method="POST" enctype="multipart/form-data">

            <div class="mb-3">
                    <label for="date" class="form-label">
                    AppointmentDate
                    </label>
    
                    <input type="date" class="form-control" id="date" name="date" required>

            <div class="d-grid gap-2">

            <div class="mb-3">
                <label for="name" class="form-label">
                  Reason for Appointment
                </label>

                <input type="text" class="form-control" id="name" name="name" placeholder="Enter product name" required>
              </div>
              
              <div class="mb-3">
                <label for="name" class="form-label">
                  Comments (Type Nil if no comments)
                </label>

                <input type="text" class="form-control" id="name" name="name" placeholder="Enter product name" required>
              </div>

                <button type="submit" class="btn btn-success">
                  Add Appointment
                </button>

                <a href="/" class="btn btn-secondary">
                  Cancel
                </a>

              </div>

            </form>

          </div>

        </div>

      </div>

    </div>

  </div>

</body>

</html>