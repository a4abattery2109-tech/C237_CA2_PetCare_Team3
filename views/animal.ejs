<!DOCTYPE html>
<html>

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    <%- include('partials/header') %>

        <div class="container">
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
            <br>
            <div class="text-center">
                <h2>Animal List</h2>
            </div>
            <br>
            <table class="table table-hover small text-center">
                <thead>
                    <tr>
                        <th width="100">Animal Name</th>
                        <th width="100">Species</th>
                        <th width="50">Description of Condition</th>
                        <th width="100">Condition Image</th>
                        <th width="50">Medical history</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let i=0; i < animal.length; i++) { %>
                        <tr>
                            <td><a href="/animal/<%= animal[i].animalId %>">
                                    <%= animal[i].animalName %>
                                </a></td>
                            <td>
                                <%= animal[i].species %>
                            </td>
                            <td>
                                <%= animal[i].condition %>
                            </td>
                            <!-- Image -->
                            <td>
                                <img src="/images/<%= animal[i].image %>" alt="<%= animal[i].animalName %>" width="50%">
                            </td>
                            <td>
                                <%= animal[i].history %>
                            </td>
                            <!-- Edit Link -->
                            <td><a href="/updateAnimal/<%= animal[i].animalId %>">Edit</a></td>
                        </tr>
                        <% } %>
                </tbody>
            </table>
        </div>
        <a href="/addAnimal" class="btn btn-primary">Add Animal</a>
</body>

</html>