<!DOCTYPE html>
<html>

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <%- include('partials/header') %>
        <div class="container">
            <p>Welcome, <%= user.username %> (<%= user.role %>)</p>
            <br>
            <div class="text-center">
                <h2>Animal List</h2>
            </div>
            <br>
            <table class="table table-hover small text-center">
                <thead>
                    <tr>
                        <th width="100">Animal Name</th>
                        <th width="100">Species</th>
                        <th width="50">Description of condition</th>
                        <th width="100">Condition Image</th>
                        <th width="50">History</th>
                        <th width="50">Edit</th>
                        <th width="100">Delete</th>
                        <th width="50">Make an appointment</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(let i=0; i < animal.length; i++) { %>
                        <tr>
                            <td><a href="/animal/<%= animal[i].animalId %>">
                                    <%= animal[i].animalName %>
                                </a></td>
                            <td>
                                <%= animal[i].species %>
                            </td>
                            <td>
                                <%= animal[i].condition %>
                            </td>
                            <td><img src="/images/<%= animal[i].image %>" width="50%"></td>
                            <td><%= animal[i].history %>
                            </td>
                            <!-- Edit Link -->
                            <td><a href="/updateAnimal/<%= animal[i].animalId %>">Edit</a></td>
                            <!-- Delete Link -->
                            <td><a href="/deleteAnimal/<%= animal[i].animalId %>"
                                    onclick="return confirm('Are you sure you want to delete this animal?')">Delete</a>
                            </td>
                            <!-- Edit Link -->
                            <td><a href="/addAppointment">Make Appointment for this Animal</a></td>
                        </tr>
                        <% } %>
                </tbody>
            </table>
        </div>
        <div class="col-md-6 text-center">
            <img src="/images/SmugDog.png" alt="Smug Dog" class="img-fluid mt-4 float-end" style="width: 300px;">
        </div>
        <div class="col-md-6 text-center">
            <img src="/images/SmugCat.png" alt="Smug Cat" class="img-fluid mt-4 float-end" style="width: 300px;">
        </div>
</body>

</html>