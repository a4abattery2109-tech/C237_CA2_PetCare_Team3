<!DOCTYPE html>
<html>

<head>
    <link rel="icon" type="image/png" href="/images/SnugglyBubblyPaws.png">
    <title>Snuggly Bubbly Paws</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
